# CatchGPT Oral Proctor — environment variables
# Copy this file to .env and fill in your keys.

# --- Required for the voice bot ---
# Gradium (STT + TTS) — https://gradium.ai
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# OpenAI (LLM via Responses API; also default question generator)
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-4.1)
OPENAI_MODEL=gpt-4.1

# --- AI detection ---
# Sapling AI detector — https://sapling.ai/docs/api/detector (free tier).
# If unset (or Sapling is down) detection falls back to a Claude heuristic.
SAPLING_API_KEY=

# Anthropic (Claude) — used as the detection fallback and optional question
# generator. Recommended so the demo degrades gracefully without Sapling.
ANTHROPIC_API_KEY=

# --- Tuning (optional) ---
# Number of oral questions to generate per exam (default 6).
NUM_QUESTIONS=6
# Models for the Claude code paths.
DETECTOR_CLAUDE_MODEL=claude-haiku-4-5-20251001
QUESTION_CLAUDE_MODEL=claude-sonnet-4-6

# --- Local dev ---
# Set ENV=local to skip the Krisp noise filter (only available on Pipecat Cloud).
ENV=local
PORT=7860

# --- Twilio (only needed for phone deployment; not used for the web demo) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
